  "keyFeatures": [
    "Multi-protocol support: SRT, WebRTC, RTSP, RTMP, HLS, MPEG-TS, RTP",
    "Automatic protocol conversion between any supported format",
    "Stream recording to fMP4 or MPEG-TS with configurable retention",
    "Playback server for recorded streams",
    "Internal, HTTP, and JWT-based authentication",
    "Prometheus-compatible metrics endpoint",
    "RESTful Control API for runtime management",
    "Hooks (external commands) for connect/disconnect/publish/read events",
    "On-demand publishing via runOnDemand hooks",
    "Raspberry Pi Camera native support",
    "Hot configuration reload without disconnecting clients",
    "Always-available streams with offline fallback segments",
    "Zero dependencies, single binary for Linux, Windows, macOS"
  ],
  "publicApiSurface": [
